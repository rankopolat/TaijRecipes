@using Microsoft.AspNetCore.Components.Forms

<div>
    @if (!string.IsNullOrEmpty(ImageUrl))
    {
        <div class="d-flex flex-column align-center mb-3">
            <MudImage Src="@ImageUrl"
                      Alt="Recipe photo"
                      ObjectFit="ObjectFit.Cover"
                      Height="200"
                      Class="rounded-lg mb-2"
                      Style="max-width: 100%;" />
            <MudButton Variant="Variant.Outlined"
                       Color="Color.Error"
                       Size="Size.Small"
                       StartIcon="@Icons.Material.Filled.Delete"
                       OnClick="RemoveImage">
                Remove Photo
            </MudButton>
        </div>
    }

    <MudButton HtmlTag="label"
               Variant="Variant.Outlined"
               Color="Color.Primary"
               StartIcon="@Icons.Material.Filled.CloudUpload">
        @(string.IsNullOrEmpty(ImageUrl) ? "Upload Photo" : "Change Photo")
        <InputFile OnChange="HandleFileSelected"
                   accept=".jpg,.jpeg,.png,.gif,.webp"
                   style="display: none;" />
    </MudButton>

    <MudText Typo="Typo.caption" Color="Color.Tertiary" Class="mt-1">
        Max 5MB. JPG, PNG, GIF, or WebP.
    </MudText>
</div>

@code {
    [Parameter] public string? ImagePath { get; set; }
    [Parameter] public string? ImageUrl { get; set; }
    [Parameter] public EventCallback<(IBrowserFile File, string PreviewUrl)> OnImageSelected { get; set; }
    [Parameter] public EventCallback OnImageRemoved { get; set; }

    private async Task HandleFileSelected(InputFileChangeEventArgs e)
    {
        var file = e.File;
        if (file == null) return;

        if (file.Size > 5 * 1024 * 1024)
        {
            return;
        }

        // Create preview URL
        var buffer = new byte[file.Size];
        await file.OpenReadStream(maxAllowedSize: 5 * 1024 * 1024).ReadAsync(buffer);
        var base64 = Convert.ToBase64String(buffer);
        var previewUrl = $"data:{file.ContentType};base64,{base64}";

        await OnImageSelected.InvokeAsync((file, previewUrl));
    }

    private async Task RemoveImage()
    {
        await OnImageRemoved.InvokeAsync();
    }
}
