@using RecipeWebsite.Models
@using RecipeWebsite.Services
@using Microsoft.AspNetCore.Components.Authorization
@inject CommentService CommentService
@inject AuthService AuthService
@inject ISnackbar Snackbar

<div>
    <MudText Typo="Typo.h5" Class="mb-3" Style="font-family: 'Playfair Display', Georgia, serif;">
        <MudIcon Icon="@Icons.Material.Filled.Comment" Class="mr-1" /> Comments
    </MudText>

    @* Add Comment Form *@
    <AuthorizeView>
        <Authorized>
            <MudPaper Class="pa-3 mb-4" Elevation="1">
                <MudTextField @bind-Value="_newComment"
                              Label="Add a comment..."
                              Variant="Variant.Outlined"
                              Lines="2"
                              Class="mb-2" />
                <MudButton Variant="Variant.Filled"
                           Color="Color.Primary"
                           Size="Size.Small"
                           OnClick="AddComment"
                           Disabled="_submitting || string.IsNullOrWhiteSpace(_newComment)"
                           StartIcon="@Icons.Material.Filled.Send">
                    @(_submitting ? "Posting..." : "Post Comment")
                </MudButton>
            </MudPaper>
        </Authorized>
        <NotAuthorized>
            <MudAlert Severity="Severity.Info" Class="mb-4">
                <MudLink Href="login" Color="Color.Primary">Sign in</MudLink> to leave a comment.
            </MudAlert>
        </NotAuthorized>
    </AuthorizeView>

    @* Comments List *@
    @if (_loading)
    {
        <MudSkeleton Width="80%" Class="mb-2" />
        <MudSkeleton Width="60%" Class="mb-2" />
    }
    else if (_comments.Any())
    {
        @foreach (var comment in _comments)
        {
            <MudPaper Class="pa-3 mb-2" Elevation="0" Style="background-color: var(--mud-palette-background-gray);">
                <div class="d-flex justify-space-between align-center mb-1">
                    <MudText Typo="Typo.subtitle2" Color="Color.Primary">
                        @(comment.AuthorDisplayName ?? "Unknown")
                    </MudText>
                    <div class="d-flex align-center gap-2">
                        <MudText Typo="Typo.caption" Color="Color.Tertiary">
                            @comment.CreatedAt.ToString("MMM dd, yyyy h:mm tt")
                        </MudText>
                        @if (comment.UserId == AuthService.CurrentUserId)
                        {
                            <MudIconButton Icon="@Icons.Material.Filled.Delete"
                                           Size="Size.Small"
                                           Color="Color.Error"
                                           OnClick="@(() => DeleteComment(comment))" />
                        }
                    </div>
                </div>
                <MudText Typo="Typo.body2">@comment.Content</MudText>
            </MudPaper>
        }
    }
    else
    {
        <MudText Typo="Typo.body2" Color="Color.Tertiary" Class="text-center py-4">
            No comments yet. Be the first!
        </MudText>
    }
</div>

@code {
    [Parameter, EditorRequired] public int RecipeId { get; set; }

    private List<Comment> _comments = new();
    private string _newComment = "";
    private bool _loading = true;
    private bool _submitting;

    protected override async Task OnInitializedAsync()
    {
        await LoadComments();
    }

    private async Task LoadComments()
    {
        _loading = true;
        try
        {
            _comments = await CommentService.GetCommentsAsync(RecipeId);
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error loading comments: {ex.Message}");
        }
        finally
        {
            _loading = false;
        }
    }

    private async Task AddComment()
    {
        if (string.IsNullOrWhiteSpace(_newComment) || AuthService.CurrentUserId == null) return;

        _submitting = true;
        try
        {
            var comment = new Comment
            {
                RecipeId = RecipeId,
                UserId = AuthService.CurrentUserId,
                Content = _newComment.Trim()
            };

            await CommentService.AddCommentAsync(comment);
            _newComment = "";
            await LoadComments();
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Error: {ex.Message}", Severity.Error);
        }
        finally
        {
            _submitting = false;
        }
    }

    private async Task DeleteComment(Comment comment)
    {
        try
        {
            await CommentService.DeleteCommentAsync(comment.Id);
            await LoadComments();
            Snackbar.Add("Comment deleted.", Severity.Success);
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Error: {ex.Message}", Severity.Error);
        }
    }
}