@using RecipeWebsite.Models
@using RecipeWebsite.Helpers
@inject NavigationManager Navigation

<div class="recipe-card" @onclick="@(() => Navigation.NavigateTo($"recipe/{Recipe.Id}"))">
    <div class="recipe-card-image">
        @if (!string.IsNullOrEmpty(Recipe.ImageUrl))
        {
            <img src="@Recipe.ImageUrl" alt="@Recipe.Title" loading="lazy" />
        }
        else
        {
            <img src="@PlaceholderImages.GetForCategory(Recipe.CategoryName)" alt="@Recipe.Title" loading="lazy" />
        }
        <div class="recipe-card-image-overlay"></div>
        @if (!string.IsNullOrEmpty(Recipe.CategoryName))
        {
            <span class="recipe-card-badge">@Recipe.CategoryName</span>
        }
    </div>
    <div class="recipe-card-body">
        <h3 class="recipe-card-title">@Recipe.Title</h3>
        @if (!string.IsNullOrEmpty(Recipe.Description))
        {
            <p class="recipe-card-desc">@Recipe.Description</p>
        }
        <div class="recipe-card-meta">
            @if (Recipe.PrepTimeMinutes.HasValue || Recipe.CookTimeMinutes.HasValue)
            {
                <span class="recipe-card-meta-item">
                    <MudIcon Icon="@Icons.Material.Filled.Schedule" Size="Size.Small" />
                    @((Recipe.PrepTimeMinutes ?? 0) + (Recipe.CookTimeMinutes ?? 0)) min
                </span>
            }
            @if (Recipe.Servings.HasValue)
            {
                <span class="recipe-card-meta-item">
                    <MudIcon Icon="@Icons.Material.Filled.Restaurant" Size="Size.Small" />
                    @Recipe.Servings servings
                </span>
            }
        </div>
    </div>
</div>

@code {
    [Parameter, EditorRequired]
    public Recipe Recipe { get; set; } = default!;
}
