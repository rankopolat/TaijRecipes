@page "/recipes"
@using RecipeWebsite.Models
@using RecipeWebsite.Services
@inject RecipeService RecipeService
@inject NavigationManager Navigation

<PageTitle>Browse Recipes</PageTitle>

<MudContainer MaxWidth="MaxWidth.Large" Class="py-6">
    <div class="section-heading">
        <div class="section-heading-accent"></div>
        <MudText Typo="Typo.h4" Style="font-family: 'Playfair Display', Georgia, serif;">
            Browse Recipes
        </MudText>
    </div>

    @* Inline search bar *@
    <div class="search-bar-inline mb-2">
        <MudIcon Icon="@Icons.Material.Filled.Search" Size="Size.Small" Style="color: #8BA888;" />
        <input type="text" placeholder="Search recipes by name..." @bind="_searchTerm" @bind:event="oninput"
               @onkeydown="HandleSearchKeyDown" />
        @if (!string.IsNullOrWhiteSpace(_searchTerm))
        {
            <MudIconButton Icon="@Icons.Material.Filled.Close" Size="Size.Small"
                           OnClick="HandleClear" Style="color: #8BA888;" />
        }
        <button class="search-btn" @onclick="SearchRecipes">Search</button>
    </div>

    @* Category filter chips *@
    @if (_categories.Any())
    {
        <div class="category-chips">
            @foreach (var cat in _categories)
            {
                <button class="category-chip @(cat.Id == _selectedCategory ? "active" : "")"
                        @onclick="@(() => OnCategorySelected(cat.Id))">
                    @if (!string.IsNullOrEmpty(cat.Icon))
                    {
                        <span>@cat.Icon</span>
                    }
                    @cat.Name
                </button>
            }
        </div>
    }

    @* Results *@
    <div style="margin-top: 1.5rem;">
        @if (_loading)
        {
            <MudGrid>
                @for (int i = 0; i < 6; i++)
                {
                    <MudItem xs="12" sm="6" md="4">
                        <MudSkeleton SkeletonType="SkeletonType.Rectangle" Height="200px" Class="rounded-lg mb-2" />
                        <MudSkeleton Width="60%" />
                        <MudSkeleton Width="40%" />
                    </MudItem>
                }
            </MudGrid>
        }
        else if (_recipes.Any())
        {
            <p class="results-count">@_recipes.Count recipe(s) found</p>
            <MudGrid>
                @foreach (var recipe in _recipes)
                {
                    <MudItem xs="12" sm="6" md="4">
                        <RecipeWebsite.Components.RecipeCard Recipe="recipe" />
                    </MudItem>
                }
            </MudGrid>
        }
        else
        {
            <div class="empty-state">
                <svg width="56" height="56" viewBox="0 0 56 56" fill="none" xmlns="http://www.w3.org/2000/svg" style="margin-bottom: 0.75rem;">
                    <circle cx="28" cy="28" r="26" fill="#4A7C59" opacity="0.06"/>
                    <circle cx="24" cy="24" r="12" fill="none" stroke="#4A7C59" stroke-width="1.5" opacity="0.18"/>
                    <path d="M33 33 L40 40" stroke="#4A7C59" stroke-width="2" opacity="0.15" stroke-linecap="round"/>
                </svg>
                <MudText Typo="Typo.body1" Color="Color.Tertiary">No recipes found. Try a different search or category.</MudText>
            </div>
        }
    </div>
</MudContainer>

@code {
    private List<Recipe> _recipes = new();
    private List<Category> _categories = new();
    private string? _searchTerm;
    private int? _selectedCategory;
    private bool _loading = true;

    protected override async Task OnInitializedAsync()
    {
        // Parse query params from URL (from hero search or category links)
        var uri = new Uri(Navigation.Uri);
        var query = System.Web.HttpUtility.ParseQueryString(uri.Query);

        if (!string.IsNullOrEmpty(query["search"]))
            _searchTerm = query["search"];

        if (int.TryParse(query["category"], out var catId))
            _selectedCategory = catId;

        _categories = await RecipeService.GetCategoriesAsync();
        await SearchRecipes();
    }

    private async Task SearchRecipes()
    {
        _loading = true;
        try
        {
            _recipes = await RecipeService.SearchRecipesAsync(_searchTerm, _selectedCategory);
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Search error: {ex.Message}");
        }
        finally
        {
            _loading = false;
        }
    }

    private async Task OnCategorySelected(int categoryId)
    {
        _selectedCategory = _selectedCategory == categoryId ? null : categoryId;
        await SearchRecipes();
    }

    private async Task HandleSearchKeyDown(Microsoft.AspNetCore.Components.Web.KeyboardEventArgs e)
    {
        if (e.Key == "Enter")
            await SearchRecipes();
    }

    private async Task HandleClear()
    {
        _searchTerm = null;
        await SearchRecipes();
    }
}
