@page "/my-recipes"
@using RecipeWebsite.Models
@using RecipeWebsite.Services
@using RecipeWebsite.Helpers
@inject RecipeService RecipeService
@inject StorageService StorageService
@inject AuthService AuthService
@inject NavigationManager Navigation
@inject ISnackbar Snackbar
@inject IDialogService DialogService

<PageTitle>My Recipes</PageTitle>

@if (!AuthService.IsAuthenticated)
{
    <MudContainer MaxWidth="MaxWidth.Small" Class="py-8 text-center">
        <MudAlert Severity="Severity.Info">Please <MudLink Href="login">sign in</MudLink> to view your recipes.</MudAlert>
    </MudContainer>
    return;
}

<MudContainer MaxWidth="MaxWidth.Large" Class="py-6">
    <div class="d-flex justify-space-between align-center mb-4">
        <MudText Typo="Typo.h4" Style="font-family: 'Playfair Display', Georgia, serif;">My Recipes</MudText>
        <MudButton Variant="Variant.Filled"
                   Color="Color.Primary"
                   StartIcon="@Icons.Material.Filled.Add"
                   OnClick="@(() => Navigation.NavigateTo("recipe/new"))">
            Add Recipe
        </MudButton>
    </div>

    @if (_loading)
    {
        <MudProgressLinear Indeterminate="true" Color="Color.Primary" />
    }
    else if (_recipes.Any())
    {
        <MudGrid>
            @foreach (var recipe in _recipes)
            {
                <MudItem xs="12" sm="6" md="4">
                    <MudCard Class="recipe-card" Elevation="2">
                        @if (!string.IsNullOrEmpty(recipe.ImageUrl))
                        {
                            <MudCardMedia Image="@recipe.ImageUrl" Height="180"
                                          Style="cursor: pointer;"
                                          @onclick="@(() => Navigation.NavigateTo($"recipe/{recipe.Id}"))" />
                        }
                        else
                        {
                            <MudCardMedia Image="@PlaceholderImages.GetForCategory(recipe.CategoryName, 400, 180)"
                                          Height="180"
                                          Style="cursor: pointer;"
                                          @onclick="@(() => Navigation.NavigateTo($"recipe/{recipe.Id}"))" />
                        }
                        <MudCardContent>
                            <MudText Typo="Typo.h6">@recipe.Title</MudText>
                            <MudText Typo="Typo.body2" Color="Color.Tertiary">
                                @(recipe.CategoryName ?? "Uncategorized") · @recipe.CreatedAt.ToString("MMM dd, yyyy")
                            </MudText>
                        </MudCardContent>
                        <MudCardActions>
                            <MudButton Variant="Variant.Text" Color="Color.Primary"
                                       StartIcon="@Icons.Material.Filled.Edit"
                                       OnClick="@(() => Navigation.NavigateTo($"recipe/edit/{recipe.Id}"))">
                                Edit
                            </MudButton>
                            <MudSpacer />
                            <MudButton Variant="Variant.Text" Color="Color.Error"
                                       StartIcon="@Icons.Material.Filled.Delete"
                                       OnClick="@(() => ConfirmDelete(recipe))">
                                Delete
                            </MudButton>
                        </MudCardActions>
                    </MudCard>
                </MudItem>
            }
        </MudGrid>
    }
    else
    {
        <MudPaper Class="pa-8 text-center my-4" Elevation="0" Style="background: transparent;">
            <svg width="64" height="64" viewBox="0 0 64 64" fill="none" xmlns="http://www.w3.org/2000/svg" style="margin-bottom: 1rem;">
                <circle cx="32" cy="32" r="30" fill="#4A7C59" opacity="0.06"/>
                <rect x="18" y="20" width="28" height="22" rx="5" fill="none" stroke="#4A7C59" stroke-width="1.5" opacity="0.18"/>
                <rect x="16" y="18" width="32" height="4" rx="2" fill="#4A7C59" opacity="0.12"/>
                <path d="M26 30 L38 30" stroke="#4A7C59" stroke-width="1.2" opacity="0.1" stroke-linecap="round"/>
                <path d="M28 36 L36 36" stroke="#4A7C59" stroke-width="1.2" opacity="0.08" stroke-linecap="round"/>
                <path d="M32 46 L32 50" stroke="#4A7C59" stroke-width="1" opacity="0.08" stroke-linecap="round"/>
                <path d="M28 50 L36 50" stroke="#4A7C59" stroke-width="1" opacity="0.06" stroke-linecap="round"/>
            </svg>
            <MudText Typo="Typo.body1" Color="Color.Tertiary" Class="mb-2">You haven't added any recipes yet.</MudText>
            <MudButton Variant="Variant.Outlined" Color="Color.Primary"
                       StartIcon="@Icons.Material.Filled.Add"
                       OnClick="@(() => Navigation.NavigateTo("recipe/new"))">
                Add Your First Recipe
            </MudButton>
        </MudPaper>
    }
</MudContainer>

@code {
    private List<Recipe> _recipes = new();
    private bool _loading = true;

    protected override async Task OnInitializedAsync()
    {
        await LoadRecipes();
    }

    private async Task LoadRecipes()
    {
        _loading = true;
        try
        {
            if (AuthService.CurrentUserId != null)
            {
                _recipes = await RecipeService.GetMyRecipesAsync(AuthService.CurrentUserId);
            }
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Error loading recipes: {ex.Message}", Severity.Error);
        }
        finally
        {
            _loading = false;
        }
    }

    private async Task ConfirmDelete(Recipe recipe)
    {
        var parameters = new DialogParameters<ConfirmDeleteDialog>
        {
            { x => x.RecipeTitle, recipe.Title }
        };

        var dialog = await DialogService.ShowAsync<ConfirmDeleteDialog>("Delete Recipe", parameters);
        var result = await dialog.Result;

        if (result != null && !result.Canceled)
        {
            try
            {
                await StorageService.DeleteImageAsync(recipe.ImagePath);
                await RecipeService.DeleteRecipeAsync(recipe.Id);
                Snackbar.Add("Recipe deleted.", Severity.Success);
                await LoadRecipes();
            }
            catch (Exception ex)
            {
                Snackbar.Add($"Error deleting recipe: {ex.Message}", Severity.Error);
            }
        }
    }
}