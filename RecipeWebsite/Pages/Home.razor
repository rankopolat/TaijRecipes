@page "/"
@using RecipeWebsite.Models
@using RecipeWebsite.Services
@inject RecipeService RecipeService
@inject NavigationManager Navigation

<PageTitle>Family Recipes</PageTitle>

<div class="hero-section">
    <div class="hero-content">
        <div class="hero-illustration">
            <svg width="72" height="72" viewBox="0 0 72 72" fill="none" xmlns="http://www.w3.org/2000/svg">
                <circle cx="36" cy="36" r="34" fill="rgba(255,255,255,0.08)"/>
                <ellipse cx="36" cy="52" rx="22" ry="5" fill="rgba(255,255,255,0.08)"/>
                <rect x="18" y="30" width="36" height="22" rx="5" fill="rgba(255,255,255,0.15)" stroke="rgba(255,255,255,0.6)" stroke-width="1.5"/>
                <rect x="15" y="28" width="42" height="4" rx="2" fill="rgba(255,255,255,0.7)"/>
                <rect x="11" y="27" width="7" height="10" rx="3" fill="none" stroke="rgba(255,255,255,0.45)" stroke-width="1.5"/>
                <rect x="54" y="27" width="7" height="10" rx="3" fill="none" stroke="rgba(255,255,255,0.45)" stroke-width="1.5"/>
                <path d="M28 23 C28 19 31 17 30 12" stroke="rgba(255,255,255,0.3)" stroke-width="1.5" fill="none" stroke-linecap="round"/>
                <path d="M36 21 C36 17 39 15 38 10" stroke="rgba(255,255,255,0.25)" stroke-width="1.5" fill="none" stroke-linecap="round"/>
                <path d="M44 23 C44 19 41 17 42 12" stroke="rgba(255,255,255,0.3)" stroke-width="1.5" fill="none" stroke-linecap="round"/>
            </svg>
        </div>
        <h3 style="font-family: 'Playfair Display', Georgia, serif; font-size: 2.2rem; font-weight: 700; margin: 0 0 0.5rem; color: white; letter-spacing: -0.01em;">
            Our Family Recipes
        </h3>
        <p style="font-size: 1.1rem; opacity: 0.8; margin: 0 0 1.5rem; font-weight: 300; letter-spacing: 0.01em;">
            Treasured dishes passed down through generations
        </p>
        <MudButton Variant="Variant.Filled"
                   Color="Color.Surface"
                   Size="Size.Large"
                   StartIcon="@Icons.Material.Filled.MenuBook"
                   OnClick="@(() => Navigation.NavigateTo("recipes"))">
            Browse Recipes
        </MudButton>
    </div>
    <div class="hero-wave">
        <svg viewBox="0 0 1200 32" preserveAspectRatio="none" xmlns="http://www.w3.org/2000/svg">
            <path d="M0,16 C200,32 400,0 600,16 C800,32 1000,0 1200,16 L1200,32 L0,32 Z" fill="#F5F7F2"/>
        </svg>
    </div>
</div>

<MudContainer MaxWidth="MaxWidth.Large" Class="py-6">
    <div class="section-divider">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" xmlns="http://www.w3.org/2000/svg">
            <path d="M12 3C9 8 7 10 7 14c0 3 2 5 5 5s5-2 5-5c0-4-2-6-5-11z"/>
            <path d="M12 22v-4" stroke="currentColor" stroke-width="1.5" fill="none"/>
        </svg>
    </div>

    <MudText Typo="Typo.h5" Class="mb-4" Style="font-family: 'Playfair Display', Georgia, serif;">
        Recently Added
    </MudText>

    @if (_loading)
    {
        <MudGrid>
            @for (int i = 0; i < 3; i++)
            {
                <MudItem xs="12" sm="6" md="4">
                    <MudSkeleton SkeletonType="SkeletonType.Rectangle" Height="200px" Class="rounded-lg mb-2" />
                    <MudSkeleton Width="60%" />
                    <MudSkeleton Width="40%" />
                </MudItem>
            }
        </MudGrid>
    }
    else if (_recipes.Any())
    {
        <MudGrid>
            @foreach (var recipe in _recipes)
            {
                <MudItem xs="12" sm="6" md="4">
                    <RecipeWebsite.Components.RecipeCard Recipe="recipe" />
                </MudItem>
            }
        </MudGrid>
    }
    else
    {
        <MudPaper Class="pa-8 text-center my-4" Elevation="0" Style="background: transparent;">
            <svg width="64" height="64" viewBox="0 0 64 64" fill="none" xmlns="http://www.w3.org/2000/svg" style="margin-bottom: 1rem;">
                <circle cx="32" cy="32" r="30" fill="#4A7C59" opacity="0.06"/>
                <rect x="16" y="24" width="32" height="20" rx="4" fill="none" stroke="#4A7C59" stroke-width="1.5" opacity="0.2"/>
                <rect x="14" y="22" width="36" height="4" rx="2" fill="#4A7C59" opacity="0.12"/>
                <line x1="24" y1="32" x2="40" y2="32" stroke="#4A7C59" stroke-width="1.5" opacity="0.12" stroke-linecap="round"/>
                <line x1="28" y1="38" x2="36" y2="38" stroke="#4A7C59" stroke-width="1.5" opacity="0.1" stroke-linecap="round"/>
            </svg>
            <MudText Typo="Typo.body1" Color="Color.Tertiary">No recipes yet. Be the first to add one!</MudText>
        </MudPaper>
    }
</MudContainer>

@code {
    private List<Recipe> _recipes = new();
    private bool _loading = true;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            _recipes = await RecipeService.GetRecentRecipesAsync(6);
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error loading recipes: {ex.Message}");
        }
        finally
        {
            _loading = false;
        }
    }
}
