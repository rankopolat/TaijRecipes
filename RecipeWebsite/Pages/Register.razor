@page "/register"
@using RecipeWebsite.Services
@inject AuthService AuthService
@inject NavigationManager Navigation

<PageTitle>Sign Up</PageTitle>

<MudContainer MaxWidth="MaxWidth.Small" Class="py-8">
    <MudCard Class="pa-4">
        <div class="auth-card-decoration">
            <svg width="56" height="56" viewBox="0 0 56 56" fill="none" xmlns="http://www.w3.org/2000/svg">
                <circle cx="28" cy="28" r="26" fill="#4A7C59" opacity="0.06"/>
                <rect x="16" y="22" width="24" height="16" rx="4" fill="#4A7C59" opacity="0.1"/>
                <rect x="14" y="20" width="28" height="4" rx="2" fill="#4A7C59" opacity="0.14"/>
                <path d="M24 16 C24 12, 32 12, 32 16" stroke="#4A7C59" stroke-width="1.2" fill="none" opacity="0.12" stroke-linecap="round"/>
                <path d="M24 14 C24 10, 32 10, 32 14" stroke="#4A7C59" stroke-width="0.8" fill="none" opacity="0.08" stroke-linecap="round"/>
                <circle cx="28" cy="30" r="2.5" fill="#D4A574" opacity="0.18"/>
                <path d="M20 42 L36 42" stroke="#4A7C59" stroke-width="0.8" opacity="0.08" stroke-linecap="round"/>
            </svg>
        </div>
        <MudCardHeader>
            <CardHeaderContent>
                <MudText Typo="Typo.h5" Style="font-family: 'Playfair Display', Georgia, serif;">Create Account</MudText>
            </CardHeaderContent>
            <CardHeaderAvatar>
                <MudIcon Icon="@Icons.Material.Filled.PersonAdd" Color="Color.Primary" />
            </CardHeaderAvatar>
        </MudCardHeader>
        <MudCardContent>
            @if (!string.IsNullOrEmpty(_error))
            {
                <MudAlert Severity="Severity.Error" Class="mb-4" ShowCloseIcon="true" CloseIconClicked="@(() => _error = null)">
                    @_error
                </MudAlert>
            }
            @if (!string.IsNullOrEmpty(_success))
            {
                <MudAlert Severity="Severity.Success" Class="mb-4">
                    @_success
                </MudAlert>
            }

            <MudTextField @bind-Value="_displayName"
                          Label="Display Name"
                          Variant="Variant.Outlined"
                          Class="mb-4"
                          Required="true"
                          Disabled="_loading"
                          HelperText="This is how your name will appear on recipes" />

            <MudTextField @bind-Value="_email"
                          Label="Email"
                          InputType="InputType.Email"
                          Variant="Variant.Outlined"
                          Class="mb-4"
                          Required="true"
                          Disabled="_loading" />

            <MudTextField @bind-Value="_password"
                          Label="Password"
                          InputType="InputType.Password"
                          Variant="Variant.Outlined"
                          Class="mb-4"
                          Required="true"
                          Disabled="_loading"
                          HelperText="At least 6 characters" />

            <MudTextField @bind-Value="_confirmPassword"
                          Label="Confirm Password"
                          InputType="InputType.Password"
                          Variant="Variant.Outlined"
                          Class="mb-4"
                          Required="true"
                          Disabled="_loading" />
        </MudCardContent>
        <MudCardActions Class="d-flex flex-column pa-4">
            <MudButton Variant="Variant.Filled"
                       Color="Color.Primary"
                       FullWidth="true"
                       Size="Size.Large"
                       OnClick="HandleRegister"
                       Disabled="_loading">
                @if (_loading)
                {
                    <MudProgressCircular Class="ms-n1" Size="Size.Small" Indeterminate="true" />
                    <MudText Class="ms-2">Creating account...</MudText>
                }
                else
                {
                    <MudText>Create Account</MudText>
                }
            </MudButton>
            <MudButton Variant="Variant.Text"
                       Color="Color.Primary"
                       FullWidth="true"
                       Class="mt-2"
                       OnClick="@(() => Navigation.NavigateTo("login"))">
                Already have an account? Sign in
            </MudButton>
        </MudCardActions>
    </MudCard>
</MudContainer>

@code {
    private string _displayName = "";
    private string _email = "";
    private string _password = "";
    private string _confirmPassword = "";
    private string? _error;
    private string? _success;
    private bool _loading;

    private async Task HandleRegister()
    {
        _error = null;
        _success = null;

        if (string.IsNullOrWhiteSpace(_displayName) || string.IsNullOrWhiteSpace(_email) ||
            string.IsNullOrWhiteSpace(_password))
        {
            _error = "Please fill in all fields.";
            return;
        }

        if (_password.Length < 6)
        {
            _error = "Password must be at least 6 characters.";
            return;
        }

        if (_password != _confirmPassword)
        {
            _error = "Passwords don't match.";
            return;
        }

        _loading = true;

        var (success, error) = await AuthService.SignUpAsync(_email, _password, _displayName);

        if (success)
        {
            Navigation.NavigateTo("");
        }
        else
        {
            _error = error;
        }

        _loading = false;
    }
}