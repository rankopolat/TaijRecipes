@page "/register"
@using RecipeWebsite.Services
@inject AuthService AuthService
@inject NavigationManager Navigation

<PageTitle>Sign Up</PageTitle>

<MudContainer MaxWidth="MaxWidth.Small" Class="py-8">
    <MudCard Class="pa-4">
        <div class="auth-card-decoration">
            <svg width="72" height="72" viewBox="0 0 72 72" fill="none" xmlns="http://www.w3.org/2000/svg">
                <circle cx="36" cy="36" r="34" fill="#4A7C59" opacity="0.04"/>
                <circle cx="36" cy="36" r="24" fill="#D4A574" opacity="0.03"/>
                <!-- Open cookbook -->
                <rect x="14" y="24" width="20" height="26" rx="2" fill="#4A7C59" opacity="0.08" transform="rotate(-5 24 37)"/>
                <rect x="38" y="24" width="20" height="26" rx="2" fill="#4A7C59" opacity="0.08" transform="rotate(5 48 37)"/>
                <path d="M34 22 L34 52" stroke="#D4A574" stroke-width="1.5" opacity="0.15"/>
                <!-- Lines on pages -->
                <line x1="18" y1="32" x2="30" y2="31" stroke="#4A7C59" stroke-width="0.8" opacity="0.08" transform="rotate(-5 24 31.5)"/>
                <line x1="18" y1="36" x2="28" y2="35" stroke="#4A7C59" stroke-width="0.8" opacity="0.06" transform="rotate(-5 23 35.5)"/>
                <line x1="18" y1="40" x2="29" y2="39" stroke="#4A7C59" stroke-width="0.8" opacity="0.06" transform="rotate(-5 23.5 39.5)"/>
                <line x1="40" y1="32" x2="54" y2="33" stroke="#4A7C59" stroke-width="0.8" opacity="0.08" transform="rotate(5 47 32.5)"/>
                <line x1="40" y1="36" x2="52" y2="37" stroke="#4A7C59" stroke-width="0.8" opacity="0.06" transform="rotate(5 46 36.5)"/>
                <!-- Heart bookmark -->
                <path d="M34 20 C32 16 28 16 28 20 C28 23 34 26 34 26 C34 26 40 23 40 20 C40 16 36 16 34 20Z" fill="#C75050" opacity="0.12"/>
            </svg>
        </div>
        <MudCardHeader>
            <CardHeaderContent>
                <MudText Typo="Typo.h5" Style="font-family: 'Playfair Display', Georgia, serif;">Create Account</MudText>
            </CardHeaderContent>
            <CardHeaderAvatar>
                <MudIcon Icon="@Icons.Material.Filled.PersonAdd" Color="Color.Primary" />
            </CardHeaderAvatar>
        </MudCardHeader>
        <MudCardContent>
            @if (!string.IsNullOrEmpty(_error))
            {
                <MudAlert Severity="Severity.Error" Class="mb-4" ShowCloseIcon="true" CloseIconClicked="@(() => _error = null)">
                    @_error
                </MudAlert>
            }
            @if (!string.IsNullOrEmpty(_success))
            {
                <MudAlert Severity="Severity.Success" Class="mb-4">
                    @_success
                </MudAlert>
            }

            <MudTextField @bind-Value="_displayName"
                          Label="Display Name"
                          Variant="Variant.Outlined"
                          Class="mb-4"
                          Required="true"
                          Disabled="_loading"
                          HelperText="This is how your name will appear on recipes" />

            <MudTextField @bind-Value="_email"
                          Label="Email"
                          InputType="InputType.Email"
                          Variant="Variant.Outlined"
                          Class="mb-4"
                          Required="true"
                          Disabled="_loading" />

            <MudTextField @bind-Value="_password"
                          Label="Password"
                          InputType="InputType.Password"
                          Variant="Variant.Outlined"
                          Class="mb-4"
                          Required="true"
                          Disabled="_loading"
                          HelperText="At least 6 characters" />

            <MudTextField @bind-Value="_confirmPassword"
                          Label="Confirm Password"
                          InputType="InputType.Password"
                          Variant="Variant.Outlined"
                          Class="mb-4"
                          Required="true"
                          Disabled="_loading" />
        </MudCardContent>
        <MudCardActions Class="d-flex flex-column pa-4">
            <MudButton Variant="Variant.Filled"
                       Color="Color.Primary"
                       FullWidth="true"
                       Size="Size.Large"
                       OnClick="HandleRegister"
                       Disabled="_loading">
                @if (_loading)
                {
                    <MudProgressCircular Class="ms-n1" Size="Size.Small" Indeterminate="true" />
                    <MudText Class="ms-2">Creating account...</MudText>
                }
                else
                {
                    <MudText>Create Account</MudText>
                }
            </MudButton>
            <MudButton Variant="Variant.Text"
                       Color="Color.Primary"
                       FullWidth="true"
                       Class="mt-2"
                       OnClick="@(() => Navigation.NavigateTo("login"))">
                Already have an account? Sign in
            </MudButton>
        </MudCardActions>
    </MudCard>
</MudContainer>

@code {
    private string _displayName = "";
    private string _email = "";
    private string _password = "";
    private string _confirmPassword = "";
    private string? _error;
    private string? _success;
    private bool _loading;

    private async Task HandleRegister()
    {
        _error = null;
        _success = null;

        if (string.IsNullOrWhiteSpace(_displayName) || string.IsNullOrWhiteSpace(_email) ||
            string.IsNullOrWhiteSpace(_password))
        {
            _error = "Please fill in all fields.";
            return;
        }

        if (_password.Length < 6)
        {
            _error = "Password must be at least 6 characters.";
            return;
        }

        if (_password != _confirmPassword)
        {
            _error = "Passwords don't match.";
            return;
        }

        _loading = true;

        var (success, error) = await AuthService.SignUpAsync(_email, _password, _displayName);

        if (success)
        {
            Navigation.NavigateTo("");
        }
        else
        {
            _error = error;
        }

        _loading = false;
    }
}