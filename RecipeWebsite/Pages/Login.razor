@page "/login"
@using RecipeWebsite.Services
@inject AuthService AuthService
@inject NavigationManager Navigation

<PageTitle>Sign In</PageTitle>

<MudContainer MaxWidth="MaxWidth.Small" Class="py-8">
    <MudCard Class="pa-4">
        <div class="auth-card-decoration">
            <svg width="60" height="60" viewBox="0 0 60 60" fill="none" xmlns="http://www.w3.org/2000/svg">
                <circle cx="30" cy="30" r="28" fill="#4A7C59" opacity="0.08"/>
                <path d="M30 12C24 18 20 23 22 30C24 37 30 40 30 40C30 40 36 37 38 30C40 23 36 18 30 12Z" fill="#4A7C59" stroke="#4A7C59" stroke-width="1" opacity="0.25"/>
                <path d="M30 22V38" stroke="#4A7C59" stroke-width="1" opacity="0.2" stroke-linecap="round"/>
                <path d="M30 28C27 25 24 25 23 26" stroke="#4A7C59" stroke-width="0.8" fill="none" opacity="0.2"/>
                <path d="M30 32C33 29 36 29 37 30" stroke="#4A7C59" stroke-width="0.8" fill="none" opacity="0.2"/>
            </svg>
        </div>
        <MudCardHeader>
            <CardHeaderContent>
                <MudText Typo="Typo.h5" Style="font-family: 'Playfair Display', Georgia, serif;">Sign In</MudText>
            </CardHeaderContent>
            <CardHeaderAvatar>
                <MudIcon Icon="@Icons.Material.Filled.Login" Color="Color.Primary" />
            </CardHeaderAvatar>
        </MudCardHeader>
        <MudCardContent>
            @if (!string.IsNullOrEmpty(_error))
            {
                <MudAlert Severity="Severity.Error" Class="mb-4" ShowCloseIcon="true" CloseIconClicked="@(() => _error = null)">
                    @_error
                </MudAlert>
            }

            <MudTextField @bind-Value="_email"
                          Label="Email"
                          InputType="InputType.Email"
                          Variant="Variant.Outlined"
                          Class="mb-4"
                          Required="true"
                          Disabled="_loading" />

            <MudTextField @bind-Value="_password"
                          Label="Password"
                          InputType="InputType.Password"
                          Variant="Variant.Outlined"
                          Class="mb-4"
                          Required="true"
                          Disabled="_loading" />
        </MudCardContent>
        <MudCardActions Class="d-flex flex-column pa-4">
            <MudButton Variant="Variant.Filled"
                       Color="Color.Primary"
                       FullWidth="true"
                       Size="Size.Large"
                       OnClick="HandleLogin"
                       Disabled="_loading">
                @if (_loading)
                {
                    <MudProgressCircular Class="ms-n1" Size="Size.Small" Indeterminate="true" />
                    <MudText Class="ms-2">Signing in...</MudText>
                }
                else
                {
                    <MudText>Sign In</MudText>
                }
            </MudButton>
            <MudButton Variant="Variant.Text"
                       Color="Color.Primary"
                       FullWidth="true"
                       Class="mt-2"
                       OnClick="@(() => Navigation.NavigateTo("register"))">
                Don't have an account? Sign up
            </MudButton>
        </MudCardActions>
    </MudCard>
</MudContainer>

@code {
    private string _email = "";
    private string _password = "";
    private string? _error;
    private bool _loading;

    private async Task HandleLogin()
    {
        if (string.IsNullOrWhiteSpace(_email) || string.IsNullOrWhiteSpace(_password))
        {
            _error = "Please enter both email and password.";
            return;
        }

        _loading = true;
        _error = null;

        var (success, error) = await AuthService.SignInAsync(_email, _password);

        if (success)
        {
            Navigation.NavigateTo("");
        }
        else
        {
            _error = error;
        }

        _loading = false;
    }
}