@page "/login"
@using RecipeWebsite.Services
@inject AuthService AuthService
@inject NavigationManager Navigation

<PageTitle>Sign In</PageTitle>

<MudContainer MaxWidth="MaxWidth.Small" Class="py-8">
    <MudCard Class="pa-4">
        <div class="auth-card-decoration">
            <svg width="72" height="72" viewBox="0 0 72 72" fill="none" xmlns="http://www.w3.org/2000/svg">
                <circle cx="36" cy="36" r="34" fill="#4A7C59" opacity="0.04"/>
                <circle cx="36" cy="36" r="24" fill="#4A7C59" opacity="0.03"/>
                <!-- Spoon + fork crossed -->
                <rect x="22" y="18" width="3" height="32" rx="1.5" fill="#D4A574" opacity="0.18" transform="rotate(-20 23.5 34)"/>
                <ellipse cx="22" cy="17" rx="4" ry="6" fill="none" stroke="#D4A574" stroke-width="1.2" opacity="0.15" transform="rotate(-20 22 17)"/>
                <rect x="47" y="18" width="3" height="32" rx="1.5" fill="#4A7C59" opacity="0.15" transform="rotate(20 48.5 34)"/>
                <path d="M47 14 L48.5 24 L50 14" stroke="#4A7C59" stroke-width="1" fill="none" opacity="0.12" transform="rotate(20 48.5 19)"/>
                <path d="M46 14 L48.5 10 L51 14" stroke="#4A7C59" stroke-width="1" fill="none" opacity="0.1" transform="rotate(20 48.5 12)"/>
                <!-- Small leaf -->
                <path d="M36 48C33 44 33 40 36 38C33 42 36 46 36 48Z" fill="#4A7C59" opacity="0.1"/>
                <path d="M36 48C39 44 39 40 36 38C39 42 36 46 36 48Z" fill="#8BA888" opacity="0.08"/>
            </svg>
        </div>
        <MudCardHeader>
            <CardHeaderContent>
                <MudText Typo="Typo.h5" Style="font-family: 'Playfair Display', Georgia, serif;">Sign In</MudText>
            </CardHeaderContent>
            <CardHeaderAvatar>
                <MudIcon Icon="@Icons.Material.Filled.Login" Color="Color.Primary" />
            </CardHeaderAvatar>
        </MudCardHeader>
        <MudCardContent>
            @if (!string.IsNullOrEmpty(_error))
            {
                <MudAlert Severity="Severity.Error" Class="mb-4" ShowCloseIcon="true" CloseIconClicked="@(() => _error = null)">
                    @_error
                </MudAlert>
            }

            <MudTextField @bind-Value="_email"
                          Label="Email"
                          InputType="InputType.Email"
                          Variant="Variant.Outlined"
                          Class="mb-4"
                          Required="true"
                          Disabled="_loading" />

            <MudTextField @bind-Value="_password"
                          Label="Password"
                          InputType="InputType.Password"
                          Variant="Variant.Outlined"
                          Class="mb-4"
                          Required="true"
                          Disabled="_loading" />
        </MudCardContent>
        <MudCardActions Class="d-flex flex-column pa-4">
            <MudButton Variant="Variant.Filled"
                       Color="Color.Primary"
                       FullWidth="true"
                       Size="Size.Large"
                       OnClick="HandleLogin"
                       Disabled="_loading">
                @if (_loading)
                {
                    <MudProgressCircular Class="ms-n1" Size="Size.Small" Indeterminate="true" />
                    <MudText Class="ms-2">Signing in...</MudText>
                }
                else
                {
                    <MudText>Sign In</MudText>
                }
            </MudButton>
            <MudButton Variant="Variant.Text"
                       Color="Color.Primary"
                       FullWidth="true"
                       Class="mt-2"
                       OnClick="@(() => Navigation.NavigateTo("register"))">
                Don't have an account? Sign up
            </MudButton>
        </MudCardActions>
    </MudCard>
</MudContainer>

@code {
    private string _email = "";
    private string _password = "";
    private string? _error;
    private bool _loading;

    private async Task HandleLogin()
    {
        if (string.IsNullOrWhiteSpace(_email) || string.IsNullOrWhiteSpace(_password))
        {
            _error = "Please enter both email and password.";
            return;
        }

        _loading = true;
        _error = null;

        var (success, error) = await AuthService.SignInAsync(_email, _password);

        if (success)
        {
            Navigation.NavigateTo("");
        }
        else
        {
            _error = error;
        }

        _loading = false;
    }
}