@page "/login"
@using RecipeWebsite.Services
@inject AuthService AuthService
@inject NavigationManager Navigation

<PageTitle>Sign In</PageTitle>

<MudContainer MaxWidth="MaxWidth.Small" Class="py-8">
    <MudCard Class="pa-4">
        <div class="auth-card-decoration">
            <svg width="56" height="56" viewBox="0 0 56 56" fill="none" xmlns="http://www.w3.org/2000/svg">
                <circle cx="28" cy="28" r="26" fill="#4A7C59" opacity="0.06"/>
                <path d="M28 10C23 16 20 20 22 26C24 32 28 34 28 34C28 34 32 32 34 26C36 20 33 16 28 10Z" fill="#4A7C59" opacity="0.12"/>
                <path d="M28 18V32" stroke="#4A7C59" stroke-width="0.8" opacity="0.15" stroke-linecap="round"/>
                <path d="M28 23C26 21 24 21 23 22" stroke="#4A7C59" stroke-width="0.6" fill="none" opacity="0.12"/>
                <path d="M28 27C30 25 32 25 33 26" stroke="#4A7C59" stroke-width="0.6" fill="none" opacity="0.12"/>
                <circle cx="28" cy="42" r="3" fill="none" stroke="#4A7C59" stroke-width="0.8" opacity="0.1"/>
                <circle cx="28" cy="42" r="1" fill="#4A7C59" opacity="0.1"/>
            </svg>
        </div>
        <MudCardHeader>
            <CardHeaderContent>
                <MudText Typo="Typo.h5" Style="font-family: 'Playfair Display', Georgia, serif;">Sign In</MudText>
            </CardHeaderContent>
            <CardHeaderAvatar>
                <MudIcon Icon="@Icons.Material.Filled.Login" Color="Color.Primary" />
            </CardHeaderAvatar>
        </MudCardHeader>
        <MudCardContent>
            @if (!string.IsNullOrEmpty(_error))
            {
                <MudAlert Severity="Severity.Error" Class="mb-4" ShowCloseIcon="true" CloseIconClicked="@(() => _error = null)">
                    @_error
                </MudAlert>
            }

            <MudTextField @bind-Value="_email"
                          Label="Email"
                          InputType="InputType.Email"
                          Variant="Variant.Outlined"
                          Class="mb-4"
                          Required="true"
                          Disabled="_loading" />

            <MudTextField @bind-Value="_password"
                          Label="Password"
                          InputType="InputType.Password"
                          Variant="Variant.Outlined"
                          Class="mb-4"
                          Required="true"
                          Disabled="_loading" />
        </MudCardContent>
        <MudCardActions Class="d-flex flex-column pa-4">
            <MudButton Variant="Variant.Filled"
                       Color="Color.Primary"
                       FullWidth="true"
                       Size="Size.Large"
                       OnClick="HandleLogin"
                       Disabled="_loading">
                @if (_loading)
                {
                    <MudProgressCircular Class="ms-n1" Size="Size.Small" Indeterminate="true" />
                    <MudText Class="ms-2">Signing in...</MudText>
                }
                else
                {
                    <MudText>Sign In</MudText>
                }
            </MudButton>
            <MudButton Variant="Variant.Text"
                       Color="Color.Primary"
                       FullWidth="true"
                       Class="mt-2"
                       OnClick="@(() => Navigation.NavigateTo("register"))">
                Don't have an account? Sign up
            </MudButton>
        </MudCardActions>
    </MudCard>
</MudContainer>

@code {
    private string _email = "";
    private string _password = "";
    private string? _error;
    private bool _loading;

    private async Task HandleLogin()
    {
        if (string.IsNullOrWhiteSpace(_email) || string.IsNullOrWhiteSpace(_password))
        {
            _error = "Please enter both email and password.";
            return;
        }

        _loading = true;
        _error = null;

        var (success, error) = await AuthService.SignInAsync(_email, _password);

        if (success)
        {
            Navigation.NavigateTo("");
        }
        else
        {
            _error = error;
        }

        _loading = false;
    }
}