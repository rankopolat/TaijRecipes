@using RecipeWebsite.Services

<div class="drawer-header">
    <svg width="36" height="36" viewBox="0 0 36 36" fill="none" xmlns="http://www.w3.org/2000/svg">
        <circle cx="18" cy="18" r="17" fill="#4A7C59" opacity="0.07"/>
        <path d="M18 6C14 11 12 14 13 19C14 24 18 26 18 26C18 26 22 24 23 19C24 14 22 11 18 6Z" fill="#4A7C59" opacity="0.15"/>
        <path d="M18 13V24" stroke="#4A7C59" stroke-width="0.7" opacity="0.12" stroke-linecap="round"/>
        <path d="M18 17C16 15.5 14.5 15.5 14 16.5" stroke="#D4A574" stroke-width="0.6" fill="none" opacity="0.2"/>
        <path d="M18 20C20 18.5 21.5 18.5 22 19.5" stroke="#D4A574" stroke-width="0.6" fill="none" opacity="0.2"/>
    </svg>
    <div class="drawer-header-title">Family Recipes</div>
    <div class="drawer-header-sub">Cookbook</div>
    <div class="drawer-header-divider"></div>
</div>

<MudNavMenu Class="py-2">
    <MudNavLink Href="" Match="NavLinkMatch.All"
                Icon="@Icons.Material.Filled.Home">
        Home
    </MudNavLink>
    <MudNavLink Href="recipes" Match="NavLinkMatch.Prefix"
                Icon="@Icons.Material.Filled.MenuBook">
        Browse Recipes
    </MudNavLink>

    <AuthorizeView>
        <Authorized>
            <MudDivider Class="my-2" />
            <MudNavLink Href="recipe/new" Match="NavLinkMatch.All"
                        Icon="@Icons.Material.Filled.AddCircle">
                Add Recipe
            </MudNavLink>
            <MudNavLink Href="my-recipes" Match="NavLinkMatch.All"
                        Icon="@Icons.Material.Filled.Favorite">
                My Recipes
            </MudNavLink>
            <MudNavLink Href="profile" Match="NavLinkMatch.All"
                        Icon="@Icons.Material.Filled.Person">
                Profile
            </MudNavLink>
        </Authorized>
    </AuthorizeView>
</MudNavMenu>
