@using RecipeWebsite.Services

<div class="drawer-header">
    <svg width="48" height="48" viewBox="0 0 48 48" fill="none" xmlns="http://www.w3.org/2000/svg">
        <circle cx="24" cy="24" r="22" fill="#4A7C59" opacity="0.08"/>
        <path d="M24 8C19 14 16 18 18 24C20 30 24 32 24 32C24 32 28 30 30 24C32 18 29 14 24 8Z" fill="#4A7C59" stroke="#4A7C59" stroke-width="1" opacity="0.2"/>
        <path d="M24 18V30" stroke="#4A7C59" stroke-width="0.8" opacity="0.15" stroke-linecap="round"/>
        <path d="M24 22C22 20 20 20 19 21" stroke="#4A7C59" stroke-width="0.7" fill="none" opacity="0.12"/>
        <path d="M24 26C26 24 28 24 29 25" stroke="#4A7C59" stroke-width="0.7" fill="none" opacity="0.12"/>
    </svg>
    <div class="drawer-header-title">Family Recipes</div>
    <div class="drawer-header-divider"></div>
</div>

<MudNavMenu Class="py-2">
    <MudNavLink Href="" Match="NavLinkMatch.All"
                Icon="@Icons.Material.Filled.Home">
        Home
    </MudNavLink>
    <MudNavLink Href="recipes" Match="NavLinkMatch.Prefix"
                Icon="@Icons.Material.Filled.MenuBook">
        Browse Recipes
    </MudNavLink>

    <AuthorizeView>
        <Authorized>
            <MudDivider Class="my-2" />
            <MudNavLink Href="recipe/new" Match="NavLinkMatch.All"
                        Icon="@Icons.Material.Filled.AddCircle">
                Add Recipe
            </MudNavLink>
            <MudNavLink Href="my-recipes" Match="NavLinkMatch.All"
                        Icon="@Icons.Material.Filled.Favorite">
                My Recipes
            </MudNavLink>
            <MudNavLink Href="profile" Match="NavLinkMatch.All"
                        Icon="@Icons.Material.Filled.Person">
                Profile
            </MudNavLink>
        </Authorized>
    </AuthorizeView>
</MudNavMenu>
