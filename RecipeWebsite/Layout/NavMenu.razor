@using RecipeWebsite.Services

<div class="drawer-header">
    <svg width="100%" height="50" viewBox="0 0 220 50" fill="none" xmlns="http://www.w3.org/2000/svg" style="display: block;">
        <!-- Kitchen shelf -->
        <rect x="10" y="38" width="200" height="3" rx="1.5" fill="#4A7C59" opacity="0.2"/>
        <!-- Jar 1 -->
        <rect x="25" y="18" width="18" height="20" rx="3" fill="#4A7C59" opacity="0.12"/>
        <rect x="27" y="14" width="14" height="6" rx="2" fill="#4A7C59" opacity="0.18"/>
        <circle cx="34" cy="28" r="3" fill="#4A7C59" opacity="0.08"/>
        <!-- Bottle -->
        <rect x="55" y="10" width="12" height="28" rx="3" fill="#D4A574" opacity="0.18"/>
        <rect x="57" y="5" width="8" height="7" rx="2" fill="#D4A574" opacity="0.22"/>
        <!-- Pot -->
        <rect x="80" y="22" width="22" height="16" rx="4" fill="#4A7C59" opacity="0.15"/>
        <rect x="78" y="20" width="26" height="4" rx="2" fill="#4A7C59" opacity="0.2"/>
        <!-- Plant/herb -->
        <path d="M130 38 L130 22" stroke="#4A7C59" stroke-width="1.5" opacity="0.2"/>
        <path d="M130 28 C125 24 122 20 125 16" stroke="#4A7C59" stroke-width="1.2" fill="none" opacity="0.18"/>
        <path d="M130 24 C135 20 138 16 135 12" stroke="#4A7C59" stroke-width="1.2" fill="none" opacity="0.18"/>
        <path d="M130 32 C124 28 121 24 124 20" stroke="#4A7C59" stroke-width="1.2" fill="none" opacity="0.15"/>
        <ellipse cx="130" cy="38" rx="8" ry="4" fill="#4A7C59" opacity="0.1"/>
        <!-- Mug -->
        <rect x="155" y="24" width="16" height="14" rx="3" fill="#D4A574" opacity="0.15"/>
        <path d="M171 27 Q178 27 178 34 Q178 38 171 38" stroke="#D4A574" stroke-width="1.5" fill="none" opacity="0.18"/>
        <!-- Cutting board -->
        <rect x="185" y="30" width="20" height="8" rx="2" fill="#D4A574" opacity="0.12"/>
        <rect x="190" y="28" width="2" height="4" rx="1" fill="#D4A574" opacity="0.15"/>
    </svg>
</div>

<MudNavMenu Class="py-2">
    <MudNavLink Href="" Match="NavLinkMatch.All"
                Icon="@Icons.Material.Filled.Home">
        Home
    </MudNavLink>
    <MudNavLink Href="recipes" Match="NavLinkMatch.Prefix"
                Icon="@Icons.Material.Filled.MenuBook">
        Browse Recipes
    </MudNavLink>

    <AuthorizeView>
        <Authorized>
            <MudDivider Class="my-2" />
            <MudNavLink Href="recipe/new" Match="NavLinkMatch.All"
                        Icon="@Icons.Material.Filled.AddCircle">
                Add Recipe
            </MudNavLink>
            <MudNavLink Href="my-recipes" Match="NavLinkMatch.All"
                        Icon="@Icons.Material.Filled.Favorite">
                My Recipes
            </MudNavLink>
            <MudNavLink Href="profile" Match="NavLinkMatch.All"
                        Icon="@Icons.Material.Filled.Person">
                Profile
            </MudNavLink>
        </Authorized>
    </AuthorizeView>
</MudNavMenu>
