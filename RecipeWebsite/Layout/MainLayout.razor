@inherits LayoutComponentBase
@using RecipeWebsite.Services
@inject AuthService AuthService
@inject NavigationManager Navigation

<MudLayout>
    <MudAppBar Elevation="2">
        <MudIconButton Icon="@Icons.Material.Filled.Menu"
                       Color="Color.Inherit"
                       Edge="Edge.Start"
                       OnClick="@ToggleDrawer" />
        <MudText Typo="Typo.h6" Style="font-family: 'Georgia', serif; cursor: pointer;"
                 @onclick="@(() => Navigation.NavigateTo(""))">
            Family Recipes
        </MudText>
        <MudSpacer />

        <AuthorizeView>
            <Authorized>
                <MudButton Variant="Variant.Text" Color="Color.Inherit"
                           StartIcon="@Icons.Material.Filled.Add"
                           OnClick="@(() => Navigation.NavigateTo("recipe/new"))"
                           Class="d-none d-sm-flex">
                    Add Recipe
                </MudButton>
                <MudMenu Icon="@Icons.Material.Filled.AccountCircle" Color="Color.Inherit">
                    <MudMenuItem OnClick="@(() => Navigation.NavigateTo("my-recipes"))"
                                 Icon="@Icons.Material.Filled.MenuBook">
                        My Recipes
                    </MudMenuItem>
                    <MudMenuItem OnClick="@(() => Navigation.NavigateTo("profile"))"
                                 Icon="@Icons.Material.Filled.Person">
                        Profile
                    </MudMenuItem>
                    <MudDivider />
                    <MudMenuItem OnClick="HandleSignOut"
                                 Icon="@Icons.Material.Filled.Logout">
                        Sign Out
                    </MudMenuItem>
                </MudMenu>
            </Authorized>
            <NotAuthorized>
                <MudButton Variant="Variant.Text" Color="Color.Inherit"
                           OnClick="@(() => Navigation.NavigateTo("login"))">
                    Sign In
                </MudButton>
            </NotAuthorized>
        </AuthorizeView>
    </MudAppBar>

    <MudDrawer @bind-Open="_drawerOpen" ClipMode="DrawerClipMode.Always" Elevation="2">
        <NavMenu />
    </MudDrawer>

    <MudMainContent>
        @Body
    </MudMainContent>
</MudLayout>

@code {
    private bool _drawerOpen = false;

    private void ToggleDrawer()
    {
        _drawerOpen = !_drawerOpen;
    }

    private async Task HandleSignOut()
    {
        await AuthService.SignOutAsync();
        Navigation.NavigateTo("");
    }
}
