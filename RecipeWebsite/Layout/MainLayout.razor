@inherits LayoutComponentBase
@using RecipeWebsite.Services
@inject AuthService AuthService
@inject NavigationManager Navigation

<MudLayout>
    <MudAppBar Elevation="0" Dense="true" Style="border-bottom: 1px solid rgba(255,255,255,0.1);">
        <MudIconButton Icon="@Icons.Material.Filled.Menu"
                       Color="Color.Inherit"
                       Edge="Edge.Start"
                       Size="Size.Small"
                       OnClick="@ToggleDrawer" />
        <span @onclick="@(() => Navigation.NavigateTo(""))" style="cursor: pointer; display: flex; align-items: center; gap: 6px;">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                <path d="M12 3C7 9 5 12 7 17C9 21 12 22 12 22C12 22 15 21 17 17C19 12 17 9 12 3Z" fill="rgba(255,255,255,0.9)"/>
                <path d="M12 10V20" stroke="rgba(255,255,255,0.4)" stroke-width="0.8" stroke-linecap="round"/>
                <path d="M12 13C10 11.5 8.5 11.5 7.5 12.5" stroke="rgba(255,255,255,0.3)" stroke-width="0.6" fill="none"/>
                <path d="M12 16C14 14.5 15.5 14.5 16.5 15.5" stroke="rgba(255,255,255,0.3)" stroke-width="0.6" fill="none"/>
            </svg>
            <span style="font-family: 'Playfair Display', Georgia, serif; font-size: 0.85rem; font-weight: 600; letter-spacing: 0.02em;">
                Family Recipes
            </span>
        </span>
        <MudSpacer />

        <AuthorizeView>
            <Authorized>
                <MudButton Variant="Variant.Text" Color="Color.Inherit"
                           StartIcon="@Icons.Material.Filled.Add"
                           Size="Size.Small"
                           OnClick="@(() => Navigation.NavigateTo("recipe/new"))"
                           Class="d-none d-sm-flex"
                           Style="font-size: 0.8rem; text-transform: none;">
                    Add Recipe
                </MudButton>
                <MudMenu Icon="@Icons.Material.Filled.AccountCircle" Color="Color.Inherit" Size="Size.Small">
                    <MudMenuItem OnClick="@(() => Navigation.NavigateTo("my-recipes"))"
                                 Icon="@Icons.Material.Filled.MenuBook">
                        My Recipes
                    </MudMenuItem>
                    <MudMenuItem OnClick="@(() => Navigation.NavigateTo("profile"))"
                                 Icon="@Icons.Material.Filled.Person">
                        Profile
                    </MudMenuItem>
                    <MudDivider />
                    <MudMenuItem OnClick="HandleSignOut"
                                 Icon="@Icons.Material.Filled.Logout">
                        Sign Out
                    </MudMenuItem>
                </MudMenu>
            </Authorized>
            <NotAuthorized>
                <MudButton Variant="Variant.Text" Color="Color.Inherit"
                           Size="Size.Small"
                           Style="font-size: 0.8rem; text-transform: none;"
                           OnClick="@(() => Navigation.NavigateTo("login"))">
                    Sign In
                </MudButton>
            </NotAuthorized>
        </AuthorizeView>
    </MudAppBar>

    <MudDrawer @bind-Open="_drawerOpen" ClipMode="DrawerClipMode.Always" Elevation="1">
        <NavMenu />
    </MudDrawer>

    <MudMainContent>
        @Body

        <footer class="site-footer">
            <div class="site-footer-brand">Family Recipes</div>
            <div class="site-footer-tagline">Treasured dishes passed down through generations</div>
            <div class="site-footer-links">
                <a @onclick="@(() => Navigation.NavigateTo(""))" style="cursor:pointer;">Home</a>
                <a @onclick="@(() => Navigation.NavigateTo("recipes"))" style="cursor:pointer;">Recipes</a>
                <AuthorizeView>
                    <Authorized>
                        <a @onclick="@(() => Navigation.NavigateTo("recipe/new"))" style="cursor:pointer;">Add Recipe</a>
                    </Authorized>
                </AuthorizeView>
            </div>
            <div class="site-footer-copy">Made with love for our family</div>
        </footer>
    </MudMainContent>
</MudLayout>

@code {
    private bool _drawerOpen = false;

    private void ToggleDrawer()
    {
        _drawerOpen = !_drawerOpen;
    }

    private async Task HandleSignOut()
    {
        await AuthService.SignOutAsync();
        Navigation.NavigateTo("");
    }
}
