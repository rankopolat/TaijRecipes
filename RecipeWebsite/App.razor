@using RecipeWebsite.Services

<MudThemeProvider Theme="_theme" IsDarkMode="false" />
<MudPopoverProvider />
<MudDialogProvider />
<MudSnackbarProvider />

<CascadingAuthenticationState>
    <Router AppAssembly="@typeof(App).Assembly">
        <Found Context="routeData">
            <RouteView RouteData="@routeData" DefaultLayout="@typeof(MainLayout)" />
            <FocusOnNavigate RouteData="@routeData" Selector="h1" />
        </Found>
        <NotFound>
            <PageTitle>Not found</PageTitle>
            <LayoutView Layout="@typeof(MainLayout)">
                <MudContainer MaxWidth="MaxWidth.Small" Class="py-8 text-center">
                    <MudIcon Icon="@Icons.Material.Filled.SearchOff" Size="Size.Large" Color="Color.Tertiary" />
                    <MudText Typo="Typo.h5" Class="mt-4">Page not found</MudText>
                    <MudText Typo="Typo.body1" Color="Color.Tertiary" Class="mb-4">
                        Sorry, there's nothing at this address.
                    </MudText>
                    <MudButton Variant="Variant.Filled" Color="Color.Primary" Href="">
                        Go Home
                    </MudButton>
                </MudContainer>
            </LayoutView>
        </NotFound>
    </Router>
</CascadingAuthenticationState>

@code {
    [Inject] private AuthService AuthService { get; set; } = default!;

    private bool _initialized;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender && !_initialized)
        {
            _initialized = true;
            try
            {
                await AuthService.InitializeAsync();
            }
            catch (Exception ex)
            {
                Console.WriteLine($"Auth init warning: {ex.Message}");
            }
        }
    }

    private MudTheme _theme = new()
    {
        PaletteLight = new PaletteLight
        {
            Primary = "#4A7C59",
            PrimaryDarken = "#365E42",
            PrimaryLighten = "#6B9E7A",
            Secondary = "#D4A574",
            SecondaryDarken = "#B8895A",
            SecondaryLighten = "#E8C49A",
            Tertiary = "#7A8B69",
            Background = "#F5F7F2",
            Surface = "#FEFFFE",
            AppbarBackground = "#3D6B4A",
            AppbarText = "#FFFFFF",
            DrawerBackground = "#F0F4EC",
            DrawerText = "#2D3B2D",
            TextPrimary = "#2D3B2D",
            TextSecondary = "#5A6B5A",
            ActionDefault = "#4A7C59",
            ActionDisabled = "#B3BDB3",
            ActionDisabledBackground = "#DEE8DE",
            Info = "#5B9BD5",
            Success = "#4A7C59",
            Warning = "#D4A574",
            Error = "#C75050",
        },
        Typography = new Typography
        {
            Default = new DefaultTypography
            {
                FontFamily = new[] { "Lato", "Segoe UI", "Roboto", "Helvetica Neue", "Arial", "sans-serif" }
            },
            H3 = new H3Typography { FontFamily = new[] { "Playfair Display", "Georgia", "serif" } },
            H4 = new H4Typography { FontFamily = new[] { "Playfair Display", "Georgia", "serif" } },
            H5 = new H5Typography { FontFamily = new[] { "Playfair Display", "Georgia", "serif" } },
            H6 = new H6Typography { FontFamily = new[] { "Playfair Display", "Georgia", "serif" } },
        },
        LayoutProperties = new LayoutProperties
        {
            DefaultBorderRadius = "12px"
        }
    };
}
